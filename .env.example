# Copy this file to `.env` at the repository root and fill in values.
# Never commit `.env` — it is gitignored.

# FRED API (Phase 3a+ suggested inflation). Free registration:
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

